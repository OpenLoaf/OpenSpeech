{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "ignoreDeprecations": "6.0",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "emitDeclarationOnly": true
  },
  "include": ["index.ts", "**/*.tsx", "**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
