# ====================================================================
# macOS 签名 / 公证 本地环境变量（仅本地 `pnpm tauri build` 用；CI 走 GitHub Secrets）
#
# 用法：复制成 src-tauri/.env 并填入真实值（.env 已被根 .gitignore 排除）。
#   cp src-tauri/.env.example src-tauri/.env
#
# Tauri CLI 不会自动读这个文件，执行 build 时需要自己加载一遍：
#   set -a && source src-tauri/.env && set +a && pnpm tauri build
# 或者：
#   pnpm dlx dotenv-cli -e src-tauri/.env -- pnpm tauri build
#
# 命名说明：变量名跟兄弟项目 OpenLoaf（publish-desktop.yml）对齐，方便跨项目复用。
# 由于 Tauri CLI 本地认 APPLE_PASSWORD 不认 APPLE_APP_SPECIFIC_PASSWORD，
# 下面为同一个 app-specific password 同时 export 了两个名字。
# ====================================================================

# —— 签名 —— #
# 本地如果 Keychain 里已经装了 Developer ID Application 证书，只需要这一个 identity 字符串：
#   从 `security find-identity -v -p codesigning` 的输出里抄 CN（双引号内部分）。
APPLE_SIGNING_IDENTITY="Developer ID Application: YOUR NAME (XXXXXXXXXX)"

# —— 证书（仅在跟 CI 一样走 base64 .p12 导入临时 keychain 时才需要）—— #
# 本地直接用 Keychain 的话这两个留空即可。
# MAC_CER_BASE64="<base64 of your .p12 file>"
# MAC_CER_PASSWORD="<.p12 导出密码>"

# —— 公证 Apple ID + App-Specific Password —— #
APPLE_ID="you@example.com"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="XXXXXXXXXX"

# Tauri CLI 本地识别的 env 名（复用上面同一个 app-specific password）
APPLE_PASSWORD="${APPLE_APP_SPECIFIC_PASSWORD}"

# —— 可选：App Store Connect API Key 方式（notarytool 原生路径，未来切换用）—— #
# APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# APPLE_API_KEY="ABCDEFGHIJ"
# APPLE_API_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_ABCDEFGHIJ.p8"
