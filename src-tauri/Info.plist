<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>NSMicrophoneUsageDescription</key>
  <string>OpenSpeech 需要访问麦克风以进行语音输入。</string>

  <!-- 输入监控：rdev::listen 监听全局快捷键（Fn / Ctrl+Win 等）。
       macOS 不强制此 key，但部分系统设置 UI 会读它来展示授权说明文案；
       提供之，体验更顺。 -->
  <key>NSInputMonitoringUsageDescription</key>
  <string>OpenSpeech 需要监听全局快捷键以触发听写录音。</string>

  <!-- 辅助功能：enigo 模拟键盘把转写文字粘贴回当前焦点输入框时需要。
       enigo 通过 CGEventPost 直接合成键盘事件，**不**走 AppleEvents/AppleScript，
       所以无需 NSAppleEventsUsageDescription 声明。 -->
  <key>NSAccessibilityUsageDescription</key>
  <string>OpenSpeech 需要辅助功能权限以将识别后的文字写入当前焦点的输入框。</string>
</dict>
</plist>
